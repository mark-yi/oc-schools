# Copy to .env.local for local Next.js development.
# Do not commit real credentials.

# Neon / Postgres
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# OpenAI embeddings for Neon pgvector semantic search
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=512
NEON_ENABLE_KEYWORD_RRF=false

# Chroma Cloud
CHROMA_HOST=api.trychroma.com
CHROMA_API_KEY=
CHROMA_TENANT=
CHROMA_DATABASE=
CHROMA_COLLECTION=lcap_narrative_chunks

# Optional API guard. Leave blank if you want the browser demo UI to call APIs directly.
# If set, /api/* accepts Authorization: Bearer or x-api-key.
DEMO_API_KEY=

# PostHog product analytics. Server routes prefer POSTHOG_PROJECT_API_KEY.
POSTHOG_PROJECT_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_FLUSH_TIMEOUT_MS=750
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Local migration inputs. These are ignored generated artifacts.
LOCAL_ANALYTICS_SQLITE=outputs/analytics/2025/analytics.sqlite
LOCAL_RAG_SQLITE=outputs/rag/2025/lcap_retrieval.sqlite
